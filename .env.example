# Copy this file to .env and adjust before running docker compose up

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
# Comma separated, e.g. http://localhost:8000,http://192.168.1.50:8000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- Database ---
POSTGRES_DB=eggshop
POSTGRES_USER=eggshop
POSTGRES_PASSWORD=eggshop
DATABASE_URL=postgres://eggshop:eggshop@db:5432/eggshop

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Email ---
# Defaults below send everything into Mailhog (see http://localhost:8025)
# so you can test signup/order/invoice emails without a real mail server.
# Once ready for real email, point these at your SMTP provider and set
# EMAIL_USE_TLS=True (most providers use port 587).
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=eggshop@example.com

# Who gets the "new order" admin notification email.
# Leave blank to notify every user with is_staff=True instead.
ADMIN_NOTIFICATION_EMAIL=

# --- Home Assistant REST API ---
# Any long random string. Sent as: Authorization: Token <this value>
HA_API_TOKEN=change-me-ha-token

# --- Site ---
SITE_NAME=Egg Shop
TIME_ZONE=Europe/Bratislava
